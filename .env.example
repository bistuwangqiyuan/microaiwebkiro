# Database Configuration
# ============================================================================
# IMPORTANT: Use DIFFERENT connection strings for different environments!
#
# For LOCAL DEVELOPMENT (migrations, Prisma Studio):
#   Use DIRECT connection: postgresql://user:pass@host/db?sslmode=require
#
# For PRODUCTION (Netlify Functions):
#   Use POOLED connection: postgresql://user:pass@host/db?sslmode=require&pgbouncer=true
#
# Get your connection strings from: https://console.neon.tech
# See DATABASE_SETUP.md for detailed instructions
# ============================================================================

# Primary database URL (use DIRECT for local dev)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# Optional: Direct URL for migrations (if using pooled URL above)
# DATABASE_URL_DIRECT="postgresql://user:password@host:5432/database?sslmode=require"

# Optional: Development branch URL
# DATABASE_URL_DEV="postgresql://user:password@dev-host:5432/database?sslmode=require"

# Netlify Identity
NETLIFY_IDENTITY_URL="https://your-site.netlify.app/.netlify/identity"

# AI API Keys (按优先级排序)
DEEPSEEK_API_KEY="your-deepseek-api-key"
GLM_API_KEY="your-glm-api-key"
MOONSHOT_API_KEY="your-moonshot-api-key"
TONGYI_API_KEY="your-tongyi-api-key"
TENCENT_API_KEY="your-tencent-api-key"
SPARK_API_KEY="your-spark-api-key"
DOUBAO_API_KEY="your-doubao-api-key"
ANTHROPIC_API_KEY="your-anthropic-api-key"
GEMINI_API_KEY="your-gemini-api-key"
DEEPAI_API_KEY="your-deepai-api-key"

# Site Configuration
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="zh"

# API Configuration
API_TIMEOUT="3000"
API_RATE_LIMIT="100"

# Optional: Analytics
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Optional: Error Tracking
# SENTRY_DSN="your-sentry-dsn"
# SENTRY_AUTH_TOKEN="your-sentry-auth-token"
